# PostgreSQL connection (for local dev outside Docker)
POSTGRES_DB=faraday
POSTGRES_USER=faraday
POSTGRES_PASSWORD=faraday
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Django settings
DJANGO_SECRET_KEY=change-this-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Next.js
NEXT_PUBLIC_API_URL=http://localhost:8000
