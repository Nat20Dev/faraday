generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Source {
  MANUAL_ENTRY
  EVENT
  CAMPAIGN
}

enum Platform {
  INSTAGRAM
  TIKTOK
  YOUTUBE
  TWITCH
  BLUESKY
}

model Creator {
  id        String   @id @default(cuid())
  name      String
  username  String   @unique
  email     String?
  address   String?
  source    Source   @default(MANUAL_ENTRY)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  socialLinks SocialLink[]
  tags        Tag[]
  notes       Note[]
}

model SocialLink {
  id        String   @id @default(cuid())
  platform  Platform
  url       String
  handle    String?
  creatorId String
  creator   Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([creatorId, platform])
}

model Tag {
  id        String   @id @default(cuid())
  key       String
  value     String?
  creatorId String
  creator   Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([creatorId, key])
}

model Note {
  id        String   @id @default(cuid())
  content   String
  creatorId String
  creator   Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
